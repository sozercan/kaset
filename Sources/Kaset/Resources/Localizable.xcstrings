            "state" : "translated",
            "value" : "ذكاء Apple"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Intelligence"
          }
        }
      }
    },
    "Enable AI Features" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تفعيل ميزات الذكاء الاصطناعي"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yapay Zeka Özelliklerini Etkinleştir"
          }
        }
      }
    },
    "When enabled, you can use natural language commands, AI-powered playlist refinement, and lyrics explanations." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عند التفعيل، يمكنك استخدام الأوامر بلغة طبيعية، وتحسين قوائم التشغيل بالذكاء الاصطناعي، وشرح كلمات الأغاني."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Etkinleştirildiğinde doğal dil komutlarını, yapay zeka destekli çalma listesi iyileştirmeyi ve şarkı sözü açıklamalarını kullanabilirsiniz."
          }
        }
      }
    },
    "Command Bar" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "شريط الأوامر"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komut Çubuğu"
          }
        }
      }
    },
    "Quick Access" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "وصول سريع"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hızlı Erişim"
          }
        }
      }
    },
    "Open the command bar to control music with natural language. Try saying \"play something chill\" or \"add jazz to queue\"." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "افتح شريط الأوامر للتحكم بالموسيقى بلغة طبيعية. جرّب قول \"شغّل شيء هادئ\" أو \"أضف جاز إلى قائمة الانتظار\"."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Müziği doğal dille kontrol etmek için komut çubuğunu açın. \"Rahat bir şey çal\" veya \"sıraya caz ekle\" demeyi deneyin."
          }
        }
      }
    },
    "Clear AI Context" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مسح سياق الذكاء الاصطناعي"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yapay Zeka Bağlamını Temizle"
          }
        }
      }
    },
    "Clears the AI session state. Use this if responses seem off or stuck." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمسح حالة جلسة الذكاء الاصطناعي. استخدمه إذا بدت الاستجابات غير صحيحة أو متوقفة."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yapay zeka oturum durumunu temizler. Yanıtlar garip görünüyorsa veya takılı kaldıysa bunu kullanın."
          }
        }
      }
    },
