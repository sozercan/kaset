    "Clears the AI session state. Use this if responses seem off or stuck.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمسح حالة جلسة الذكاء الاصطناعي. استخدمه إذا بدت الاستجابات غير صحيحة أو متوقفة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Löscht den Status der KI-Sitzung. Verwende dies, wenn Antworten unpassend wirken oder festhängen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Borra el estado de la sesión de la IA. Úsalo si las respuestas parecen incorrectas o atascadas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Efface l'état de la session IA. Utilisez ceci si les réponses semblent incorrectes ou bloquées."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Menghapus status sesi AI. Gunakan ini jika respons tampak aneh atau macet."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancella lo stato della sessione AI. Usalo se le risposte sembrano sbagliate o bloccate."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AI 세션 상태를 지웁니다. 응답이 이상하거나 멈춘 것 같으면 사용하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wist de status van de AI-sessie. Gebruik dit als reacties vreemd lijken of vastzitten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czyści stan sesji AI. Użyj tego, jeśli odpowiedzi wydają się nieprawidłowe lub utknęły."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Limpa o estado da sessão da IA. Use isso se as respostas parecerem estranhas ou travadas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очищает состояние сеанса AI. Используйте это, если ответы кажутся неверными или зависли."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Rensar AI-sessionens tillstånd. Använd detta om svaren verkar felaktiga eller har fastnat."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yapay zeka oturum durumunu temizler. Yanıtlar garip görünüyorsa veya takılı kaldıysa bunu kullanın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Очищає стан сеансу ШІ. Використовуйте, якщо відповіді здаються некоректними або зависли."
          }
        }
      }
    },
