    "Fetch and display real-time synced lyrics when available": {
      "comment": "A toggle that enables or disables the feature.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جلب وعرض كلمات الأغاني المتزامنة في الوقت الفعلي عند توفرها"
          }
        },
        "de": {
          "stringUnit": {
