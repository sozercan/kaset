          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Obtener y mostrar letras sincronizadas en tiempo real cuando estén disponibles"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
