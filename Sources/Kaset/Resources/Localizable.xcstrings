    "The equalizer activates as soon as you start playback.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم تفعيل المعادل فور بدء التشغيل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Equalizer wird aktiviert, sobald du die Wiedergabe startest."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El ecualizador se activa en cuanto inicias la reproducción."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'égaliseur s'active dès que vous lancez la lecture."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Equalizer akan aktif segera setelah Anda mulai pemutaran."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'equalizzatore si attiva non appena avvii la riproduzione."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "재생을 시작하면 이퀄라이저가 바로 활성화됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De equalizer wordt geactiveerd zodra je met afspelen begint."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Korektor aktywuje się, gdy tylko rozpoczniesz odtwarzanie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O equalizador é ativado assim que você inicia a reprodução."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эквалайзер активируется, как только вы начнете воспроизведение."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Equalizern aktiveras så snart du startar uppspelningen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Oynatmaya başladığınız anda ekolayzır etkinleşir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Еквалайзер активується, щойно ви почнете відтворення."
          }
        }
      }
    },
    "Couldn't capture Kaset's audio (status %lld). Check Screen & System Audio Recording permission in System Settings.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر التقاط صوت Kaset (الحالة %lld). تحقق من إذن تسجيل الشاشة وصوت النظام في إعدادات النظام."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kasets Audio konnte nicht erfasst werden (Status %lld). Prüfe die Berechtigung für Bildschirm- und Systemaudioaufnahme in den Systemeinstellungen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo capturar el audio de Kaset (estado %lld). Comprueba el permiso de Grabación de pantalla y audio del sistema en Configuración del Sistema."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de capturer l'audio de Kaset (état %lld). Vérifiez l'autorisation Enregistrement de l'écran et de l'audio système dans les Réglages Système."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak dapat menangkap audio Kaset (status %lld). Periksa izin Perekaman Layar & Audio Sistem di Pengaturan Sistem."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile acquisire l'audio di Kaset (stato %lld). Controlla il permesso Registrazione schermo e audio di sistema nelle Impostazioni di Sistema."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaset의 오디오를 캡처할 수 없습니다 (상태 %lld). 시스템 설정에서 화면 및 시스템 오디오 녹음 권한을 확인하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kon de audio van Kaset niet vastleggen (status %lld). Controleer in Systeeminstellingen de toestemming voor Scherm- en systeemaudio-opname."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie udało się przechwycić dźwięku Kaset (stan %lld). Sprawdź uprawnienie Ekran i nagrywanie dźwięku systemowego w Ustawieniach systemowych."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível capturar o áudio do Kaset (status %lld). Verifique a permissão de Gravação de Tela e Áudio do Sistema nos Ajustes do Sistema."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось захватить аудио Kaset (статус %lld). Проверьте разрешение «Запись экрана и системного аудио» в Системных настройках."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunde inte fånga Kasets ljud (status %lld). Kontrollera behörigheten Skärminspelning och systemljudinspelning i Systeminställningar."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaset'in sesi yakalanamadı (durum %lld). Sistem Ayarları'nda Ekran ve Sistem Sesi Kaydı iznini kontrol edin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не вдалося захопити аудіо Kaset (стан %lld). Перевірте дозвіл «Запис екрана та системного звуку» у Системних налаштуваннях."
          }
        }
      }
    },
    "Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتح إعدادات النظام ← الخصوصية والأمان ← تسجيل الشاشة وصوت النظام وقم بتفعيل Kaset، ثم أعد تشغيل المعادل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffne Systemeinstellungen → Datenschutz und Sicherheit → Bildschirm- und Systemaudioaufnahme, aktiviere Kaset und schalte dann den Equalizer erneut ein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre Configuración del Sistema → Privacidad y seguridad → Grabación de pantalla y audio del sistema, activa Kaset y vuelve a activar el ecualizador."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrez Réglages Système → Confidentialité et sécurité → Enregistrement de l'écran et de l'audio système, activez Kaset, puis réactivez l'égaliseur."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Buka Pengaturan Sistem → Privasi & Keamanan → Perekaman Layar & Audio Sistem dan aktifkan Kaset, lalu aktifkan kembali equalizer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri Impostazioni di Sistema → Privacy e Sicurezza → Registrazione schermo e audio di sistema e abilita Kaset, quindi riattiva l'equalizzatore."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 설정 → 개인정보 보호 및 보안 → 화면 및 시스템 오디오 녹음에서 Kaset을 활성화한 후 이퀄라이저를 다시 켜주세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Systeeminstellingen → Privacy en beveiliging → Scherm- en systeemaudio-opname, schakel Kaset in en zet daarna de equalizer opnieuw aan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Otwórz Ustawienia systemowe → Prywatność i ochrona → Ekran i nagrywanie dźwięku systemowego i włącz Kaset, a następnie ponownie włącz korektor."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra Ajustes do Sistema → Privacidade e Segurança → Gravação de Tela e Áudio do Sistema, ative o Kaset e depois ative o equalizador novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте Системные настройки → Конфиденциальность и безопасность → Запись экрана и системного аудио и включите Kaset, затем снова включите эквалайзер."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Öppna Systeminställningar → Integritet och säkerhet → Skärminspelning och systemljudinspelning, aktivera Kaset och slå sedan på equalizern igen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem Ayarları → Gizlilik ve Güvenlik → Ekran ve Sistem Sesi Kaydı'nı açıp Kaset'i etkinleştirin, ardından ekolayzırı tekrar açın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відкрийте Системні налаштування → Конфіденційність і безпека → Запис екрана та системного звуку, увімкніть Kaset, а потім знову увімкніть еквалайзер."
          }
        }
      }
    },
    "Couldn't create the equalizer audio device. Restarting Kaset usually fixes this.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر إنشاء جهاز صوت المعادل. عادةً ما يؤدي إعادة تشغيل Kaset إلى حل المشكلة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Audioausgabegerät des Equalizers konnte nicht erstellt werden. Ein Neustart von Kaset behebt das normalerweise."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo crear el dispositivo de audio del ecualizador. Reiniciar Kaset suele solucionar esto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de créer le périphérique audio de l'égaliseur. Redémarrer Kaset résout généralement ce problème."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak dapat membuat perangkat audio equalizer. Memulai ulang Kaset biasanya menyelesaikan masalah ini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile creare il dispositivo audio dell'equalizzatore. Riavviare Kaset di solito risolve il problema."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이퀄라이저 오디오 장치를 생성할 수 없습니다. Kaset을 재시작하면 보통 해결됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kon het audioapparaat van de equalizer niet aanmaken. Kaset opnieuw starten lost dit meestal op."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie udało się utworzyć urządzenia audio korektora. Ponowne uruchomienie Kaset zwykle rozwiązuje ten problem."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível criar o dispositivo de áudio do equalizador. Reiniciar o Kaset geralmente resolve isso."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось создать аудиоустройство эквалайзера. Обычно это решается перезапуском Kaset."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunde inte skapa equalizerns ljudenhet. Om du startar om Kaset brukar det lösa problemet."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ekolayzır ses cihazı oluşturulamadı. Kaset'i yeniden başlatmak genellikle bu sorunu çözer."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не вдалося створити аудіопристрій еквалайзера. Перезапуск Kaset зазвичай вирішує цю проблему."
          }
        }
      }
    },
    "The equalizer requires macOS 14.2 or later.": {
