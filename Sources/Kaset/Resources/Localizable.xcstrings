    "How far apart suggestions are placed (every N of your playlist's songs)": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مدى تباعد الاقتراحات (كل N من أغاني قائمتك)"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie weit Vorschläge voneinander entfernt eingefügt werden (nach jeweils N Titeln deiner Playlist)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Con qué separación se colocan las sugerencias (cada N canciones de tu playlist)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Espacement des suggestions (tous les N morceaux de votre playlist)"
          }
        },
        "id": {
