    "Save playlists and subscribe to podcasts on YouTube Music to see them here.": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احفظ قوائم التشغيل واشترك في البودكاست على YouTube Music لتراها هنا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Speichere Playlists und abonniere Podcasts auf YouTube Music, um sie hier zu sehen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda playlists y suscríbete a podcasts en YouTube Music para verlos aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistrez des playlists et abonnez-vous à des podcasts sur YouTube Music pour les voir ici."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Simpan daftar putar dan berlangganan podcast di YouTube Music untuk melihatnya di sini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Salva playlist e abbonati ai podcast su YouTube Music per vederli qui."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여기에서 보려면 YouTube Music에서 재생목록을 저장하고 팟캐스트를 구독하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bewaar afspeellijsten en abonneer je op podcasts op YouTube Music om ze hier te zien."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapisuj playlisty i subskrybuj podcasty w YouTube Music, aby zobaczyć je tutaj."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Salve playlists e inscreva-se em podcasts no YouTube Music para vê-los aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сохраняйте плейлисты и подписывайтесь на подкасты в YouTube Music, чтобы видеть их здесь."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Spara spellistor och prenumerera på poddar i YouTube Music för att se dem här."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Burada görmek için YouTube Music'te çalma listeleri kaydedin ve podcastlere abone olun."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Зберігайте плейлисти та підписуйтеся на подкасти в YouTube Music, щоб побачити їх тут."
          }
        }
      }
    },
    "Save playlists, follow artists, and subscribe to podcasts on YouTube Music to see them here.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احفظ قوائم التشغيل، وتابع الفنانين، واشترك في البودكاست على YouTube Music لتراها هنا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Speichere Playlists, folge Interpreten und abonniere Podcasts auf YouTube Music, um sie hier zu sehen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda playlists, sigue artistas y suscríbete a podcasts en YouTube Music para verlos aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistrez des playlists, suivez des artistes et abonnez-vous à des podcasts sur YouTube Music pour les voir ici."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Simpan daftar putar, ikuti artis, dan berlangganan podcast di YouTube Music untuk melihatnya di sini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Salva playlist, segui artisti e abbonati ai podcast su YouTube Music per vederli qui."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여기에서 보려면 YouTube Music에서 재생목록을 저장하고, 아티스트를 구독하고, 팟캐스트를 구독하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bewaar afspeellijsten, volg artiesten en abonneer je op podcasts op YouTube Music om ze hier te zien."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapisuj playlisty, obserwuj artystów i subskrybuj podcasty w YouTube Music, aby zobaczyć je tutaj."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Salve playlists, siga artistas e inscreva-se em podcasts no YouTube Music para vê-los aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сохраняйте плейлисты, подписывайтесь на исполнителей и подкасты в YouTube Music, чтобы видеть их здесь."
          }
        },
        "sv": {
