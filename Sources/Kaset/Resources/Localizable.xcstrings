          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ambil dan tampilkan lirik tersinkron waktu nyata jika tersedia"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Recupera e mostra testi sincronizzati in tempo reale quando disponibili"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용 가능한 경우 실시간 동기화 가사를 가져와 표시합니다"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Haal gesynchroniseerde songteksten in realtime op en toon ze wanneer beschikbaar"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pobieraj i wyświetlaj zsynchronizowane teksty w czasie rzeczywistym, gdy są dostępne"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Buscar e exibir letras sincronizadas em tempo real quando disponíveis"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Получать и показывать синхронизированные тексты в реальном времени, когда они доступны"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Hämta och visa synkroniserad sångtext i realtid när den är tillgänglig"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
