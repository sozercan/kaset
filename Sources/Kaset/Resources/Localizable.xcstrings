    "%@ %@": {
      "comment": "A title that displays the version number of the app. The argument is the string “Version”.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ %2$@"
          }
        }
      }
    },
    "%@, %@, %@": {
      "comment": "A card that displays a thumbnail, title, and subtitle. The title and subtitle are combined to form a single accessibility label.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@, %2$@, %3$@"
          }
        }
      }
    },
    "%lld": {
      "comment": "A row index, starting at 1.",
      "isCommentAutoGenerated": true
    },
