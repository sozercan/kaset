      }
    },
    "•": {
      "comment": "A separator between the show name and the date.",
      "isCommentAutoGenerated": true
    },
    "⌘K": {
      "comment": "A keyboard shortcut for the command bar.",
      "isCommentAutoGenerated": true
    },
